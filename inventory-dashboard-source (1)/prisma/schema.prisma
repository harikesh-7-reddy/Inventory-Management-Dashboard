generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Shop {
  id           Int       @id @default(autoincrement())
  shopName     String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]

  @@map("shops")
}

model Session {
  id        Int      @id @default(autoincrement())
  shopId    Int
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([expiresAt])
  @@map("sessions")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]

  @@map("categories")
}

model Supplier {
  id            Int       @id @default(autoincrement())
  name          String
  email         String?   @unique
  phone         String?
  address       String?
  leadTimeDays  Int       @default(7)
  rating        Decimal   @default(3) @db.Decimal(2, 1)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  products      Product[]
  reorders      Reorder[]

  @@map("suppliers")
}

model Product {
  id            Int             @id @default(autoincrement())
  sku           String          @unique
  name          String
  description   String?
  categoryId    Int
  supplierId    Int
  unit          String          @default("pcs")
  unitCost      Decimal         @db.Decimal(10, 2)
  price         Decimal         @db.Decimal(10, 2)
  stockQty      Int             @default(0)
  reorderPoint  Int             @default(10)
  reorderQty    Int             @default(50)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  category      Category        @relation(fields: [categoryId], references: [id])
  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  stockMovements StockMovement[]
  reorders      Reorder[]
  alerts        Alert[]

  @@index([categoryId])
  @@index([supplierId])
  @@map("products")
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  productId Int
  type      MovementType
  qty       Int
  reason    String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

model Reorder {
  id         Int       @id @default(autoincrement())
  productId  Int
  supplierId Int
  qty        Int
  status     ReorderStatus @default(PENDING)
  unitCost   Decimal   @db.Decimal(10, 2)
  totalCost  Decimal   @db.Decimal(12, 2)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  receivedAt DateTime?
  product    Product   @relation(fields: [productId], references: [id])
  supplier   Supplier  @relation(fields: [supplierId], references: [id])

  @@index([status])
  @@index([productId])
  @@map("reorders")
}

model Alert {
  id             Int       @id @default(autoincrement())
  productId      Int
  severity       AlertSeverity
  message        String
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())
  product        Product   @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([severity])
  @@map("alerts")
}

enum MovementType {
  IN
  OUT
  ADJUST
}

enum ReorderStatus {
  PENDING
  SENT
  RECEIVED
  CANCELLED
}

enum AlertSeverity {
  CRITICAL
  LOW
  WATCH
}
